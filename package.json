{
    "name": "codama-spec-monorepo",
    "private": true,
    "scripts": {
        "build": "turbo run build --log-order grouped",
        "lint": "turbo run lint --log-order grouped",
        "lint:fix": "turbo run lint:fix --log-order grouped && pnpm prettier --ignore-unknown --write './*'",
        "test": "turbo run test --log-order grouped",
        "generate": "pnpm --filter @codama/spec build && pnpm --filter @codama/spec generate && pnpm --filter @codama-internal/gen-ts-node-types generate",
        "release": "tsx scripts/release/src/index.ts",
        "release:status": "tsx scripts/release/src/index.ts status",
        "release:version": "tsx scripts/release/src/index.ts version",
        "release:publish": "tsx scripts/release/src/index.ts publish"
    },
    "devDependencies": {
        "@solana/eslint-config-solana": "^5.0.0",
        "@solana/prettier-config-solana": "0.0.6",
        "@types/node": "^25",
        "@types/semver": "^7.7.1",
        "eslint": "^9.39.4",
        "prettier": "^3.8.3",
        "rimraf": "^6.1.3",
        "semver": "^7.7.4",
        "smol-toml": "^1.6.1",
        "tsup": "^8.5.1",
        "tsx": "^4.21.0",
        "turbo": "^2.9.9",
        "typescript": "^6.0.3",
        "vitest": "^4.1.5",
        "yaml": "^2.8.4"
    },
    "engines": {
        "node": ">=20.18.0"
    },
    "packageManager": "pnpm@10.33.3",
    "prettier": "@solana/prettier-config-solana",
    "pnpm": {
        "onlyBuiltDependencies": ["esbuild", "unrs-resolver"]
    }
}
