{
    "$schema": "https://turbo.build/schema.json",
    "globalEnv": ["NODE_ENV"],
    "remoteCache": {
        "signature": true
    },
    "tasks": {
        "build": {
            "dependsOn": ["^build"]
        },
        "test": {
            "dependsOn": ["build"]
        },
        "test:types": {},
        "lint": {
            "dependsOn": ["^build"],
            "inputs": ["$TURBO_DEFAULT$", "$TURBO_ROOT$/eslint.config.*"],
            "outputs": []
        },
        "lint:fix": {
            "dependsOn": ["^build"],
            "inputs": ["$TURBO_DEFAULT$", "$TURBO_ROOT$/eslint.config.*"],
            "outputs": ["*"]
        }
    }
}
